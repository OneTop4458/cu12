{
  "name": "@cu12/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "once": "tsx src/index.ts --once",
    "cleanup:retention": "tsx src/retention-cleanup.ts",
    "dispatch:sync": "tsx src/queue-dispatch.ts --type=SYNC",
    "dispatch:autolearn": "tsx src/queue-dispatch.ts --type=AUTOLEARN",
    "dispatch:digest": "tsx src/queue-dispatch.ts --type=MAIL_DIGEST",
    "test:unit": "tsx --test src/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cu12/core": "file:../../packages/core",
    "@prisma/client": "^6.19.3",
    "cheerio": "^1.0.0",
    "nodemailer": "^9.0.1",
    "playwright": "^1.61.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3"
  }
}

