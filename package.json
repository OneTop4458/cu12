{
  "name": "cu12-automation",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev:web": "npm --workspace @cu12/web run dev",
    "build:web": "npm --workspace @cu12/web run build",
    "start:web": "npm --workspace @cu12/web run start",
    "worker": "npm --workspace @cu12/worker run dev",
    "worker:once": "npm --workspace @cu12/worker run once",
    "lint": "npm --workspace @cu12/web run lint",
    "check:text": "node scripts/check-text-quality.mjs && node scripts/check-replacement-characters.mjs",
    "check:openapi": "node scripts/check-openapi-sync.mjs",
    "check:text:replacements": "node scripts/check-replacement-characters.mjs",
    "typecheck": "npm --workspace @cu12/web run typecheck && npm --workspace @cu12/worker run typecheck",
    "prisma:generate": "npm --workspace @cu12/web run prisma:generate",
    "prisma:migrate": "npm --workspace @cu12/web run prisma:migrate",
    "prisma:push": "npx prisma db push --schema prisma/schema.prisma",
    "ai:worktree": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ai-worktree-create.ps1",
    "ai:ship": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ai-pr.ps1",
    "postinstall": "npm run prisma:generate"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
