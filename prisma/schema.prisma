generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum SiteNoticeType {
  BROADCAST
  MAINTENANCE
}

enum PolicyDocumentType {
  PRIVACY_POLICY
  TERMS_OF_SERVICE
}

enum AccountStatus {
  CONNECTED
  NEEDS_REAUTH
  ERROR
}

enum PortalProvider {
  CU12
  CYBER_CAMPUS
}

enum CourseStatus {
  ACTIVE
  UPCOMING
  ENDED
}

enum LearningTaskState {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum LearningActivityType {
  VOD
  MATERIAL
  QUIZ
  ASSIGNMENT
  ETC
}

enum JobType {
  SYNC
  AUTOLEARN
  NOTICE_SCAN
  MAIL_DIGEST
}

enum JobStatus {
  PENDING
  BLOCKED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum PortalSessionStatus {
  ACTIVE
  EXPIRED
  INVALID
}

enum PortalApprovalStatus {
  PENDING
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELED
}

enum AuditSeverity {
  INFO
  WARN
  ERROR
}

enum AuditCategory {
  AUTH
  ADMIN
  IMPERSONATION
  JOB
  WORKER
  MAIL
  PARSER
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  name           String
  passwordHash   String
  isActive       Boolean            @default(true)
  withdrawnAt    DateTime?
  isTestUser     Boolean            @default(false)
  role           UserRole           @default(USER)
  lastLoginAt    DateTime?
  lastLoginIp    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  cu12Account    Cu12Account?
  inviteUsages   InviteToken[]      @relation("InviteUsedBy")
  createdInvites InviteToken[]      @relation("InviteCreatedBy")
  jobs           JobQueue[]
  courseSnapshots CourseSnapshot[]
  courseNotices  CourseNotice[]
  notifications  NotificationEvent[]
  portalMessages PortalMessage[]
  portalSessions PortalSession[]
  portalApprovalSessions PortalApprovalSession[]
  learningTasks  LearningTask[]
  learningRuns   LearningRun[]
  mailSubs       MailSubscription[]
  mailDeliveries MailDelivery[]
  taskDeadlineAlerts TaskDeadlineAlert[]
  auditActorLogs AuditLog[]         @relation("AuditActor")
  auditTargetLogs AuditLog[]        @relation("AuditTarget")
  createdSiteNotices SiteNotice[]   @relation("SiteNoticeCreator")
  updatedPolicyDocuments PolicyDocument[] @relation("PolicyUpdatedBy")
  updatedPolicyProfiles  PolicyProfile[]  @relation("PolicyProfileUpdatedBy")
  policyConsents UserPolicyConsent[]
}

model InviteToken {
  id              String    @id @default(cuid())
  provider        PortalProvider @default(CU12)
  cu12Id          String
  role            UserRole  @default(USER)
  tokenHash       String    @unique
  isActive        Boolean   @default(true)
  createdByUserId String?
  usedByUserId    String?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  usedAt          DateTime?
  createdBy       User?     @relation("InviteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  usedBy          User?     @relation("InviteUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([provider, cu12Id])
}

model Cu12Account {
  id                     String        @id @default(cuid())
  userId                 String        @unique
  provider               PortalProvider @default(CU12)
  cu12Id                 String
  encryptedPassword      String
  campus                 String?
  accountStatus          AccountStatus @default(CONNECTED)
  statusReason           String?
  autoLearnEnabled       Boolean       @default(true)
  quizAutoSolveEnabled   Boolean       @default(true)
  detectActivitiesEnabled Boolean      @default(true)
  emailDigestEnabled     Boolean       @default(true)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  user                   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cu12Id])
  @@index([provider])
}

model JobQueue {
  id             String    @id @default(cuid())
  userId         String
  type           JobType
  status         JobStatus @default(PENDING)
  payload        Json
  result         Json?
  idempotencyKey String?
  attempts       Int       @default(0)
  runAfter       DateTime  @default(now())
  workerId       String?
  startedAt      DateTime?
  finishedAt     DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, type, runAfter, createdAt])
  @@index([userId, createdAt])
  @@index([userId, type, status, finishedAt])
  @@index([idempotencyKey])
}

model SiteNotice {
  id             String        @id @default(cuid())
  type           SiteNoticeType
  title          String
  message        String
  isActive       Boolean       @default(true)
  visibleFrom    DateTime?
  visibleTo      DateTime?
  priority       Int           @default(0)
  createdByUserId String?
  createdByUser   User?         @relation("SiteNoticeCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([type, isActive, createdAt])
  @@index([isActive, visibleFrom, visibleTo])
  @@index([priority, createdAt])
}

model PolicyDocument {
  id               String             @id @default(cuid())
  type             PolicyDocumentType @unique
  version          Int                @default(1)
  content          String
  isActive         Boolean            @default(true)
  updatedByUserId  String?
  updatedByUser    User?              @relation("PolicyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([isActive, updatedAt])
}

model PolicyProfile {
  id                String   @id @default("default")
  companyName       String?
  supportEmail      String?
  companyAddress    String?
  dpoName           String?
  dpoTitle          String?
  dpoEmail          String?
  dpoPhone          String?
  jurisdictionCourt String?
  effectiveDate     String?
  revisionDate      String?
  updatedByUserId   String?
  updatedByUser     User?    @relation("PolicyProfileUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model UserPolicyConsent {
  id             String             @id @default(cuid())
  userId         String
  policyType     PolicyDocumentType
  policyVersion  Int
  consentedAt    DateTime           @default(now())
  consentIp      String?
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, policyType])
  @@index([policyType, policyVersion])
  @@index([consentedAt])
}

model WorkerHeartbeat {
  workerId   String   @id
  lastSeenAt DateTime
  updatedAt  DateTime @updatedAt

  @@index([lastSeenAt])
}

model AuthRateLimit {
  key         String   @id
  scope       String
  identifier  String
  failCount   Int      @default(0)
  windowStart DateTime @default(now())
  blockedUntil DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope, identifier])
  @@index([blockedUntil])
}

model CourseSnapshot {
  id             String      @id @default(cuid())
  userId         String
  provider       PortalProvider @default(CU12)
  lectureSeq     Int
  externalLectureId String?
  title          String
  instructor     String?
  progressPercent Int       @default(0)
  remainDays     Int?
  recentLearnedAt DateTime?
  periodStart    DateTime?
  periodEnd      DateTime?
  status         CourseStatus
  syncedAt       DateTime
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, lectureSeq])
  @@index([userId, provider, status])
}

model CourseNotice {
  id         String   @id @default(cuid())
  userId     String
  provider   PortalProvider @default(CU12)
  lectureSeq Int
  externalLectureId String?
  noticeKey  String
  title      String
  author     String?
  postedAt   DateTime?
  bodyText   String
  isNew      Boolean  @default(false)
  isRead     Boolean  @default(false)
  syncedAt   DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, lectureSeq, noticeKey])
  @@index([userId, provider, lectureSeq, postedAt])
  @@index([userId, provider, isRead, lectureSeq])
}

model NotificationEvent {
  id          String   @id @default(cuid())
  userId      String
  provider    PortalProvider @default(CU12)
  notifierSeq String
  courseTitle String
  category    String
  message     String
  occurredAt  DateTime?
  isCanceled  Boolean  @default(false)
  isUnread    Boolean  @default(true)
  isArchived  Boolean  @default(false)
  syncedAt    DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, notifierSeq])
  @@index([userId, provider, occurredAt])
}

model PortalSession {
  id                   String              @id @default(cuid())
  userId               String
  provider             PortalProvider
  encryptedCookieState String
  status               PortalSessionStatus @default(ACTIVE)
  lastVerifiedAt       DateTime?
  expiresAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([provider, status, expiresAt])
}

model PortalApprovalSession {
  id                   String               @id @default(cuid())
  userId               String
  jobId                String               @unique
  provider             PortalProvider
  status               PortalApprovalStatus @default(PENDING)
  encryptedCookieState String
  methods              Json?
  selectedWay          Int?
  selectedParam        String?
  selectedTarget       String?
  authSeq              String?
  requestCode          String?
  displayCode          String?
  errorMessage         String?
  expiresAt            DateTime
  completedAt          DateTime?
  canceledAt           DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider, status, expiresAt])
}

model PortalMessage {
  id         String   @id @default(cuid())
  userId     String
  provider   PortalProvider @default(CU12)
  messageSeq String
  title      String
  senderId   String?
  senderName String?
  bodyText   String
  sentAt     DateTime?
  isRead     Boolean  @default(false)
  syncedAt   DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, messageSeq])
  @@index([userId, provider, sentAt])
  @@index([userId, provider, isRead, sentAt])
}

model LearningTask {
  id               String            @id @default(cuid())
  userId           String
  provider         PortalProvider    @default(CU12)
  lectureSeq       Int
  externalLectureId String?
  courseContentsSeq Int
  weekNo           Int
  lessonNo         Int
  activityType     LearningActivityType @default(VOD)
  requiredSeconds  Int               @default(0)
  learnedSeconds   Int               @default(0)
  state            LearningTaskState @default(PENDING)
  availableFrom    DateTime?
  dueAt            DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, lectureSeq, courseContentsSeq])
  @@index([userId, provider, state])
  @@index([userId, provider, state, dueAt])
}

model LearningRun {
  id         String   @id @default(cuid())
  userId     String
  provider   PortalProvider @default(CU12)
  lectureSeq Int
  externalLectureId String?
  startedAt  DateTime
  endedAt    DateTime?
  status     String
  message    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider, startedAt])
}

model MailSubscription {
  id               String   @id @default(cuid())
  userId           String   @unique
  email            String
  enabled          Boolean  @default(true)
  alertOnNotice    Boolean  @default(true)
  alertOnDeadline  Boolean  @default(true)
  alertOnAutolearn Boolean  @default(true)
  digestEnabled    Boolean  @default(true)
  digestHour       Int      @default(8)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([enabled, digestEnabled])
}

model MailDelivery {
  id          String   @id @default(cuid())
  userId      String
  toEmail     String
  subject     String
  status      String
  error       String?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TaskDeadlineAlert {
  id               String   @id @default(cuid())
  userId           String
  provider         PortalProvider @default(CU12)
  lectureSeq       Int
  externalLectureId String?
  courseContentsSeq Int
  thresholdDays    Int
  dueAt            DateTime
  alertedAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, lectureSeq, courseContentsSeq, thresholdDays, dueAt])
  @@index([userId, provider, dueAt])
}

model AuditLog {
  id           String       @id @default(cuid())
  category     AuditCategory
  severity     AuditSeverity @default(INFO)
  actorUserId  String?
  targetUserId String?
  message      String
  meta         Json?
  createdAt    DateTime     @default(now())
  actor        User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target       User?        @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([category, createdAt])
  @@index([targetUserId, createdAt])
}


